APP_NAME="Exile to Exile"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_CONTACT_EMAIL=
# Debug: overlay each passive-tree node's skill id. Off unless set to "true".
VITE_DEBUG_TREE_IDS=false

# Data-cache version is derived from the committed stamp
# (public/tree/current/version.json) - no manual value needed. Set POE_DATA_VERSION
# only to force-override it (normally unset).

# Discord webhook that gets a "new patch" announcement; leave blank to disable.
DISCORD_PATCH_WEBHOOK=

# Game-data release pipeline (staged extraction, CI validation, atomic swap).
# Where staged releases and the `current` symlink live; defaults to storage/game-data.
# POE_DATA_RELEASES_ROOT=
# Shared secret CI presents to POST /api/data/activate; blank disables the endpoint.
POE_DATA_ACTIVATE_TOKEN=
# Rollback releases kept alongside the live one when pruning (default 2).
# POE_DATA_KEEP_RELEASES=2

# GitHub dispatch for the data-contract workflow (validates a staged release).
# Fine-grained PAT for this repo with Actions read/write only; blank disables.
GITHUB_DISPATCH_TOKEN=
GITHUB_REPOSITORY=
# GITHUB_DATA_WORKFLOW=data-contract.yml
# GITHUB_DISPATCH_REF=main

STATS_USER=
STATS_PASS=

# Contact address advertised in the poe2scout User-Agent (see config/poe.php).
CONTACT_EMAIL=

# poe2scout economy prices (loot-filter generator). The API is public - no auth - so
# these are optional overrides; defaults live in config/poe.php.
# POE2SCOUT_BASE_URL=https://api.poe2scout.com
# POE2SCOUT_REALM=poe2
# poe2scout asks sustained clients to identify themselves with a contactable User-Agent.
# By default APP_ENV is tagged on (e.g. local dev sends "ExileToExile/1.0-local (…)");
# set this only to override the whole string.
# POE2SCOUT_USER_AGENT="ExileToExile/1.0 (+https://your-application-url; contact: you@example.com)"
# Comma-separated canonical league names to sync (the API's exact `Value`, e.g.
# "Runes of Aldur"); blank = auto (current league). Quote it - names contain spaces.
# POE2SCOUT_LEAGUES="Runes of Aldur"
# Push-monitor URL (e.g. Uptime Kuma) pinged after a successful economy sync; blank = off.
# POE2SCOUT_SYNC_HEARTBEAT_URL=

# Newsletter delivery goes through Resend: set MAIL_MAILER=resend (above,
# defaults to log which silently writes mail to laravel.log) plus this key.
RESEND_API_KEY=

# Proof-of-work captcha (captchaapi.eu) on the newsletter signup form. Off by
# default - a blank key alone is not enough, since the package's own default
# is enabled - so local dev / CI needs no live site key. Set to true plus
# both keys (from https://captchaapi.eu/dashboard) to exercise it for real.
CAPTCHAAPI_ENABLED=false
CAPTCHAAPI_SITE_KEY=
CAPTCHAAPI_SECRET_KEY=
