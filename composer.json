{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "rajtik76/exile-to-exile",
    "type": "project",
    "description": "A free, open-source companion for Path of Exile 2 builds.",
    "keywords": [
        "path-of-exile",
        "poe2",
        "laravel",
        "react",
        "inertia"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "inertiajs/inertia-laravel": "^3.0",
        "jaybizzle/crawler-detect": "^1.4",
        "laravel/chisel": "^0.1.0",
        "laravel/framework": "^13.7",
        "laravel/tinker": "^3.0",
        "laravel/wayfinder": "^0.1.14",
        "predis/predis": "^3.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.1",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9.3",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-browser": "^4.3",
        "pestphp/pest-plugin-laravel": "^4.1",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve --host=localhost\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "lint": [
            "pint --parallel"
        ],
        "lint:check": [
            "pint --parallel --test"
        ],
        "checks": [
            "Composer\\Config::disableProcessTimeout",
            "npm run lint:check",
            "npm run format:check",
            "npm run types:check",
            "npm run test:js",
            "rector process --dry-run",
            "@lint:check",
            "@types:check"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "@checks",
            "@test:exclude-contract"
        ],
        "types:check": [
            "phpstan analyse"
        ],
        "cache:clear": [
            "@php artisan optimize:clear --ansi"
        ],
        "test": [
            "@cache:clear",
            "@php ./vendor/bin/pest --parallel --order-by=random"
        ],
        "test:exclude-contract": [
            "@cache:clear",
            "@php ./vendor/bin/pest --parallel --order-by=random --testsuite=Unit,Feature,Browser"
        ],
        "test:contract": [
            "@cache:clear",
            "@php ./vendor/bin/pest --parallel --order-by=random --testsuite=Contract"
        ],
        "test:exclude-snapshots": [
            "@cache:clear",
            "@php ./vendor/bin/pest --parallel --order-by=random --testsuite=Unit,Feature"
        ],
        "test:update-snapshots": [
            "@cache:clear",
            "@php ./vendor/bin/pest --parallel --update-snapshots --testsuite=Browser"
        ],
        "test:js": [
            "npm run test:js"
        ],
        "review": [
            "Composer\\Config::disableProcessTimeout",
            "@checks",
            "@test:exclude-snapshots"
        ],
        "review:full": [
            "@ci:check",
            "@test:contract"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-install-cmd": [
            "@php -r \"is_dir('.git') && exec('git config core.hooksPath .githooks');\""
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [],
            "installer": {
                "post-create-project": []
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
